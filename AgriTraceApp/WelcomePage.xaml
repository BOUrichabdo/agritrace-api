<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AgriTraceApp.WelcomePage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F7FB">

    <Grid RowDefinitions="*,Auto">

        <!-- ========================= -->
        <!-- BACKGROUND -->
        <!-- ========================= -->

        <Grid>

            <!-- TOP GRADIENT -->
            <Border StrokeThickness="0">

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">

                        <GradientStop Color="#166534"
                                      Offset="0.0"/>

                        <GradientStop Color="#15803D"
                                      Offset="0.5"/>

                        <GradientStop Color="#22C55E"
                                      Offset="1.0"/>

                    </LinearGradientBrush>
                </Border.Background>

            </Border>

            <!-- DECORATION -->
            <Ellipse Fill="#FFFFFF"
                     Opacity="0.07"
                     WidthRequest="280"
                     HeightRequest="280"
                     HorizontalOptions="End"
                     VerticalOptions="Start"
                     Margin="0,-80,-80,0"/>

            <Ellipse Fill="#FFFFFF"
                     Opacity="0.05"
                     WidthRequest="220"
                     HeightRequest="220"
                     HorizontalOptions="Start"
                     VerticalOptions="End"
                     Margin="-80,0,0,-50"/>

            <!-- CONTENT -->
            <ScrollView>

                <VerticalStackLayout Padding="28,70,28,40"
                                     Spacing="28">

                    <!-- ========================= -->
                    <!-- LOGO -->
                    <!-- ========================= -->

                    <Border WidthRequest="110"
                            HeightRequest="110"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            HorizontalOptions="Center"
                            StrokeShape="RoundRectangle 35"
                            Shadow="{Shadow Brush=Black,Opacity=0.15,Radius=20}">

                        <Grid>

                            <Image Source="logo.png"
                                   HeightRequest="65"
                                   WidthRequest="65"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>

                        </Grid>

                    </Border>

                    <!-- ========================= -->
                    <!-- TITLE -->
                    <!-- ========================= -->

                    <VerticalStackLayout Spacing="10">

                        <Label Text="AgriTrace ERP"
                               FontSize="34"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="White"/>

                        <Label Text="Gestion intelligente des palettes agricoles"
                               FontSize="16"
                               HorizontalTextAlignment="Center"
                               TextColor="#DCFCE7"/>

                    </VerticalStackLayout>

                    <!-- ========================= -->
                    <!-- CARD -->
                    <!-- ========================= -->

                    <Border BackgroundColor="White"
                            Padding="25"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 35"
                            Shadow="{Shadow Brush=Black,Opacity=0.10,Radius=18}">

                        <VerticalStackLayout Spacing="24">

                            <!-- Feature 1 -->
                            <Grid ColumnDefinitions="55,*">

                                <Border WidthRequest="48"
                                        HeightRequest="48"
                                        BackgroundColor="#DCFCE7"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16">

                                    <Label Text="📦"
                                           FontSize="24"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>

                                </Border>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2">

                                    <Label Text="Gestion des palettes"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#111827"/>

                                    <Label Text="Réception, stock et sortie en temps réel"
                                           FontSize="13"
                                           TextColor="#6B7280"/>

                                </VerticalStackLayout>

                            </Grid>

                            <!-- Feature 2 -->
                            <Grid ColumnDefinitions="55,*">

                                <Border WidthRequest="48"
                                        HeightRequest="48"
                                        BackgroundColor="#DBEAFE"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16">

                                    <Label Text="📊"
                                           FontSize="24"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>

                                </Border>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2">

                                    <Label Text="Traçabilité complète"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#111827"/>

                                    <Label Text="Suivi ferme → réception → expédition"
                                           FontSize="13"
                                           TextColor="#6B7280"/>

                                </VerticalStackLayout>

                            </Grid>

                            <!-- Feature 3 -->
                            <Grid ColumnDefinitions="55,*">

                                <Border WidthRequest="48"
                                        HeightRequest="48"
                                        BackgroundColor="#FEF3C7"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16">

                                    <Label Text="☁️"
                                           FontSize="24"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>

                                </Border>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2">

                                    <Label Text="Mini ERP SaaS"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#111827"/>

                                    <Label Text="Multi sociétés et multi utilisateurs"
                                           FontSize="13"
                                           TextColor="#6B7280"/>

                                </VerticalStackLayout>

                            </Grid>

                        </VerticalStackLayout>

                    </Border>

                    <!-- ========================= -->
                    <!-- BUTTONS -->
                    <!-- ========================= -->

                    <VerticalStackLayout Spacing="14">

                        <!-- LOGIN -->
                        <Button Text="Se connecter" 
                                x:Name="BTNLOGIN"
                                HeightRequest="62"
                                CornerRadius="22"
                                FontSize="18"
                                FontAttributes="Bold"
                                BackgroundColor="White"
                                TextColor="#166534"
                                Clicked="BTNLOGIN_Clicked"/>

                        <!-- CREATE ACCOUNT -->
                        <Button Text="Créer une entreprise"
                                HeightRequest="62"
                                CornerRadius="22"
                                FontSize="18"
                                FontAttributes="Bold"
                                BackgroundColor="#14532D"
                                BorderColor="#DCFCE7"
                                BorderWidth="1"
                                TextColor="White"
                                x:Name="BTNSOCITE"
                                Clicked="BTNSOCITE_Clicked"/>

                    </VerticalStackLayout>

                    <!-- VERSION -->
                    <Label Text="AgriTrace ERP • Version MVP 2026"
                           FontSize="12"
                           TextColor="#DCFCE7"
                           HorizontalOptions="Center"/>

                </VerticalStackLayout>

            </ScrollView>

        </Grid>

    </Grid>

</ContentPage>