<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgriTraceApp.Variete"
             Title="Variete">



    <!-- ROOT -->
    <Grid RowDefinitions="Auto,Auto,Auto,*"
       Padding="15"
      RowSpacing="10">

        <!-- 🟢 HEADER -->
        <Label Text="🌱 Variétés"
           FontSize="22"
           FontAttributes="Bold"
           Grid.Row="0"/>

        <!-- ➕ FORMULAIRE AJOUT -->
        <Border Grid.Row="1"
            Stroke="#E0E0E0"
            BackgroundColor="White"
            StrokeShape="RoundRectangle 15"
            Padding="15">

            <VerticalStackLayout Spacing="10">

                <Entry Placeholder="Nom variété" TextChanged="TXT_VARIETE_TextChanged"
                   x:Name="TXT_VARIETE"/>

                <Label x:Name="NomError"
                   TextColor="Red"
                   IsVisible="False"/>


                <!-- 👇 PICKER CATEGORIE -->
                <Picker Title="🌿 Choisir catégorie"
                x:Name="CMBOCATEGORIE"
                ItemDisplayBinding="{Binding Intitule}" />

                <Label x:Name="CategorieError"
               TextColor="Red"
               IsVisible="False"/>




                <Button Text="Ajouter"
                    x:Name="VALIDER"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    Clicked="VALIDER_Clicked"/>

            </VerticalStackLayout>

        </Border>

        <!-- 🔎 FILTRE -->
        <Border Grid.Row="2"
            Stroke="#E0E0E0"
            BackgroundColor="White"
            StrokeShape="RoundRectangle 12"
            Padding="10">

            <VerticalStackLayout Spacing="10">

                <Label Text="🔎 Recherche"
                   FontAttributes="Bold"/>

                <Entry x:Name="SearchEntry"
                   Placeholder="Rechercher une variété..."
                   TextChanged="SearchEntry_TextChanged"/>

            </VerticalStackLayout>

        </Border>

        <!-- 📋 LISTE -->
        <CollectionView x:Name="VarieteList"
                    Grid.Row="3">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <SwipeView>

                        <!-- ✏️ MODIFIER -->
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Modifier"
                                       BackgroundColor="Orange"
                                       CommandParameter="{Binding .}"
                                       Invoked="SwipeItem_Invoked"/>
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <!-- 🗑 SUPPRIMER -->
                        <SwipeView.LeftItems>
                            <SwipeItems>
                                <SwipeItem Text="Supprimer"
                                       BackgroundColor="Red"
                                       CommandParameter="{Binding .}"
                                       Invoked="SwipeItem_Invoked_1"/>
                            </SwipeItems>
                        </SwipeView.LeftItems>

                        <!-- CARD -->
                        <Border Stroke="#E0E0E0"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 12"
                            Padding="12"
                            Margin="0,5">

                            <VerticalStackLayout Spacing="5">

                                <!-- ICON -->
                                <Label Text="🌱"
                                   FontSize="30"
                                   HorizontalOptions="Center"/>

                                <!-- NOM -->
                                <Label Text="{Binding Intitule}"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   HorizontalOptions="Center"/>

                                <!-- CATEGORIE -->
                                <Label Text="{Binding Categorie.Nom}"
                                   TextColor="Gray"
                                   FontSize="12"
                                   HorizontalOptions="Center"/>

                            </VerticalStackLayout>

                        </Border>

                    </SwipeView>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>



</ContentPage>