<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgriTraceApp.Agriculteur"
             Title="Agriculteur">

    <!-- ROOT = GRID (IMPORTANT POUR SCROLL) -->
    <Grid RowDefinitions="Auto,Auto,Auto,*"
          Padding="15"
          RowSpacing="10">

        <!-- 🟢 HEADER -->
        <Label Text="👨‍🌾 Agriculteurs"
               FontSize="22"
               FontAttributes="Bold"
               Grid.Row="0"/>

        <!-- ➕ FORMULAIRE AJOUT -->
        <Border Grid.Row="1"
                Stroke="#E0E0E0"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 15"
                Padding="15">

            <VerticalStackLayout Spacing="10">

                <Entry Placeholder="Nom agriculteur" x:Name="TXT_AGRICULTEUR" TextChanged="TXT_AGRICULTEUR_TextChanged"/>
                <Label x:Name="NomError" TextColor="Red" IsVisible="False"/>

                <Entry Placeholder="Téléphone" x:Name="TELE"/>
                
                <Label x:Name="TelError" TextColor="Red" IsVisible="False"/>

                <Entry Placeholder="Adresse" x:Name="ADRESSE" TextChanged="ADRESSE_TextChanged"/>
                <Label x:Name="AdrError" TextColor="Red" IsVisible="False"/>


                <Button Text="Ajouter" x:Name="VALIDER"
                        Clicked="VALIDER_Clicked"
                        BackgroundColor="#2E7D32"
                        TextColor="White"/>

            </VerticalStackLayout>

        </Border>


        <!-- 🔎 FILTRE -->
        <Border Grid.Row="2"
        Stroke="#E0E0E0"
        BackgroundColor="White"
        StrokeShape="RoundRectangle 12"
        Padding="10">

            <VerticalStackLayout Spacing="10">

                <Label Text="🔎 Recherche"
               FontAttributes="Bold"/>

                <Entry x:Name="SearchEntry"
               Placeholder="Rechercher un agriculteur..."
               TextChanged="SearchEntry_TextChanged"/>

            </VerticalStackLayout>

        </Border>

    

        <!-- 📋 LISTE (SCROLL OK) -->
        <CollectionView x:Name="AgriculteurList1"
                Grid.Row="3">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <!-- 🔥 SWIPE CONTAINER -->
                    <SwipeView>

                        <!-- 🟠 MODIFIER (RIGHT) -->
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Modifier" x:Name="UPDATE"
                       BackgroundColor="Orange"
                       CommandParameter="{Binding .}"
                       Invoked="UPDATE_Invoked_1"/>
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <!-- 🔴 SUPPRIMER (LEFT) -->
                        <SwipeView.LeftItems>
                            <SwipeItems>
                                <SwipeItem Text="Supprimer" x:Name="DELETE"
                       BackgroundColor="Red"
                       CommandParameter="{Binding .}"
                       Invoked="DELETE_Invoked_1"/>
                            </SwipeItems>
                        </SwipeView.LeftItems>

                        <!-- CONTENT -->
                        <Border Stroke="#E0E0E0"
            BackgroundColor="White"
            StrokeShape="RoundRectangle 10"
            Padding="10">

                            <VerticalStackLayout>

                                <Label Text="👨‍🌾"
                   FontSize="30"
                   HorizontalOptions="Center"/>

                                <Label Text="{Binding Nom}"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

                                <Label Text="{Binding Telephone}"
                   TextColor="Gray"
                   HorizontalOptions="Center"/>

                            </VerticalStackLayout>

                        </Border>

                    </SwipeView>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>