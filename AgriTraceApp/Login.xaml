<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgriTraceApp.Login"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F3F4F6">

    <Grid RowDefinitions="2.2*,3*">

        <!-- ========================= -->
        <!-- HEADER AVEC DÉGRADÉ       -->
        <!-- ========================= -->
        <Grid Grid.Row="0">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 0,0,40,40">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#14532D" Offset="0" />
                        <GradientStop Color="#0A2E1A" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Icône de paramètres (en haut à droite) -->
                    <ImageButton Source="user.png"
                                 WidthRequest="28"
                                 HeightRequest="28"
                                 BackgroundColor="Transparent"
                                 HorizontalOptions="End"
                                 VerticalOptions="Start"
                                 Margin="20,20,20,0"
                                 Opacity="0.7"
                                 Clicked="ImageButton_Clicked" />

                    <BoxView Color="White" Opacity="0.03"/>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="10">
                        
                        
                        <Border BackgroundColor="#DCFCE7"
                                WidthRequest="85"
                                HeightRequest="85"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 50">
                            <Border.Shadow>
                                <Shadow Brush="#000000"
                                        Opacity="0.15"
                                        Radius="18"
                                        Offset="0,4" />
                            </Border.Shadow>
                            <Image Source="user.png"
                                   HeightRequest="55"
                                   WidthRequest="55"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <!--<Label Text="AgriTrace"
                               FontSize="30"
                               FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment ="Center" />-->
                        <Label Text="Plateforme intelligente de traçabilité agricole"
                               FontSize="13"
                               TextColor="#D1FAE5"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <!-- ========================= -->
        <!-- CARTE DE CONNEXION        -->
        <!-- ========================= -->
        <Border Grid.Row="1"
                Margin="18,-30,18,18"
                Padding="24,20"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 35">
            <Border.Shadow>
                <Shadow Brush="#000000"
                        Opacity="0.10"
                        Radius="25"
                        Offset="0,6" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="16">
                <!-- Titre -->
                <VerticalStackLayout Spacing="2">
                    <Label Text="Connexion"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#111827" />
                    <Label Text="Connectez-vous pour accéder à votre espace"
                           FontSize="12"
                           TextColor="#6B7280" />
                </VerticalStackLayout>

                <!-- Champ Utilisateur -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Utilisateur"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#374151" />
                    <Border BackgroundColor="#F3F4F6"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16">
                        <Entry x:Name="TXT_USER"
                               Placeholder="Nom utilisateur"
                               HeightRequest="50"
                               Margin="15,0"
                               FontSize="15"
                               TextColor="Black"
                               PlaceholderColor="#9CA3AF"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Champ Mot de passe avec œil -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Mot de passe"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#374151" />
                    <Border BackgroundColor="#F3F4F6"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16">
                        <Grid>
                            <Entry x:Name="TXT_PASSWORD"
                                   Placeholder="Saisir votre mot de passe"
                                   IsPassword="True"
                                   HeightRequest="50"
                                   Margin="15,0,50,0"
                                   FontSize="15"
                                   TextColor="Black"
                                   PlaceholderColor="#9CA3AF"
                                   VerticalOptions="Center" />
                            <ImageButton x:Name="btnTogglePassword"
                                         Source="eye_closed.png"
                                         WidthRequest="24"
                                         HeightRequest="24"
                                         HorizontalOptions="End"
                                         VerticalOptions="Center"
                                         Margin="0,0,15,0"
                                         BackgroundColor="Transparent"
                                         Clicked="btnTogglePassword_Clicked_1" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Bouton Connexion -->
                <Button x:Name="BTNCONNECTER"
                        Text="Se connecter"
                        HeightRequest="52"
                        CornerRadius="18"
                        FontSize="16"
                        FontAttributes="Bold"
                        BackgroundColor="#16A34A"
                        TextColor="White"
                        Clicked="BTNCONNECTER_Clicked">
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Scale" Value="0.96" />
                                    <Setter Property="BackgroundColor" Value="#0F8B3A" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Button>

                <!-- Lien Mot de passe oublié -->
                <Label Text="Mot de passe oublié ?"
                       HorizontalOptions="Center"
                       TextColor="#16A34A"
                       FontAttributes="Bold"
                       FontSize="13">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

                <!-- Séparateur -->
                <BoxView HeightRequest="1"
                         Color="#E5E7EB"
                         Margin="0,2" />

                <!-- Bouton Créer une société (style outline) -->
                <Button x:Name="BTN_CREER_SOCIETE"
                        Text="➕  Créer une société"
                        HeightRequest="46"
                        CornerRadius="18"
                        FontSize="14"
                        FontAttributes="Bold"
                        BackgroundColor="Transparent"
                        TextColor="#16A34A"
                        BorderColor="#16A34A"
                        BorderWidth="2"
                        Clicked="BTN_CREER_SOCIETE_Clicked">
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Scale" Value="0.96" />
                                    <Setter Property="BackgroundColor" Value="#16A34A" />
                                    <Setter Property="TextColor" Value="White" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Button>

                <!-- Footer -->
                <VerticalStackLayout Spacing="1" Margin="0,4,0,0">
                    <Label Text="AgriTrace ERP"
                           FontAttributes="Bold"
                           FontSize="12"
                           HorizontalOptions="Center"
                           TextColor="#374151" />
                    <Label Text="Version MVP 2026"
                           FontSize="11"
                           HorizontalOptions="Center"
                           TextColor="#9CA3AF" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!-- Indicateur de chargement -->
        <ActivityIndicator x:Name="LoadingIndicator"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    IsRunning="False"
                    IsVisible="False"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>
    </Grid>
</ContentPage>